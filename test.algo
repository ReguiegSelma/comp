// ============================================================
//  Programme de test AVEC ERREURS — MiniAlgo
// ============================================================

PROGRAM TestComp

DECL
    /* Variables simples */
    INTEGER : A, B, C ;
    FLOAT   : X ;

    /* Constantes */
    CONST MAX = 10 ;
    CONST PI  = 3.14 ;

    /* Tableau d'entiers (5 cases) */
    INTEGER : T[5] ;
    INTEGER : F[10] ;
ENDDECL

BEGIN

    /* ---- Affectations simples ---- */
    A = 5 ;
    B = 3 ;
    C = A + B ;

    /* ---- Erreurs d'affectation ---- */
    X = PI ;

    /* ---- IF / ELSE avec erreur syntaxique ---- */
    IF (A > B) {
        WRITE(A) ;
    }ELSE{
        WRITE(B) ;
    }

    /* ---- FOR avec erreur ---- */
    FOR (C : 0 : 4 : 1) {
        T[C] = C + 1 ;
    }


    READ(C) ;
    WRITE(C) ;
    WRITE(A) ;

END